
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id          Int      @id @default(autoincrement())
  identifier  String   @unique // NIS / NISN / NIP
  name        String
  email       String   @unique
  password    String
  role        Role     @default(MEMBER)

  isResetPending Boolean @default(false) 
  pendingNewPassword String?

  qrSecret    String?   @unique @default(uuid())

  isApproved          Boolean   @default(true)

  //relasi
  transaction Transaction[]
  favorites   Favorite[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Genre {
  id          Int       @id @default(autoincrement())
  name        String    @unique

  //relasi
  books       Book[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Book {
  id          Int       @id @default(autoincrement())
  bookCode    String    @unique //code di buku perpus (misal: buku-001)
  title       String
  author      String
  publisher   String?
  coverImage  String? //menyimpan url/path gambar 
  synopsis    String    @db.Text
  stock       Int       @default(1)

  isRecommended Boolean   @default(false)

  // relasi
  genres      Genre[]
  transaction Transaction[]
  favorites   Favorite[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Favorite {
  id          Int       @id @default(autoincrement())
  userId      Int
  bookId      Int

  //relasi
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  book        Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([userId, bookId])
}

model Transaction {
  id          Int       @id @default(autoincrement())
  userId      Int?
  bookId      Int?

  status      TransactionStatus @default(PENDING_BORROW)

  //pencatatan waktu
  borrowDate  DateTime?
  dueDate     DateTime?
  returnDate  DateTime?

  //foreign keys
  user        User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  book        Book?              @relation(fields: [bookId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  ADMIN
  MEMBER
}

enum TransactionStatus {
  PENDING_BORROW
  BORROWED
  PENDING_RETURN
  RETURNED
  REJECTED
}